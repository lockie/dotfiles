[user]
	email = awkravchuk@gmail.com
	name = Andrew Kravchuk
	signingkey = 50F6285F
[gui]
	fontdiff = -family Consolas -size 12 -weight normal -slant roman -underline 0 -overstrike 0
	tabsize = 4


[diff "lisp"]
	xfuncname = "^((\\s*\\((def|eval-when)|;;;).*)$"
[pull]
	rebase = true
	ff = only
[push]
	default = matching
[merge]
	tool = meld
[alias]
	co = checkout
	st = status
	br = branch
	g = gui
	df = diff
	ch = cherry-pick
	c = clone
[commit]
	gpgsign = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[diff]
	algorithm=histogram
	colormoved=default
[core]
	pager=diff-highlight | $PAGER
[init]
	defaultBranch = main
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
